{
  "experiment": "exp2_models",
  "description": "Cross-model comparison: FCA improvement by model size",
  "domain": "countries",
  "methods": [{"name": "fca_guided", "type": "ours"}],
  "models": [
    {"name": "qwen2.5:1.5b", "size": "1.5B"},
