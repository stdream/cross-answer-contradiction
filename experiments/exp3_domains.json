{
  "experiment": "exp3_domains",
  "description": "Cross-domain: factual → commonsense → specialized",
  "model": "qwen2.5:7b",
  "domains": ["countries", "animals", "se_concepts"],
  "methods": [
    {"name": "vanilla", "type": "baseline"},
    {"name": "selfconsistency_k5", "type": "baseline", "params": {"k": 5}},
    {"name": "fca_guided", "type": "ours"}
  ],
  "metrics": ["cross_answer_contradiction_rate", "knowledge_accuracy_f1"],
  "max_steps": 300,
  "seed": 42
}
